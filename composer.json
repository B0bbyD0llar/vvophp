{
  "name": "bitartist/vvophp",
  "description": "PHP library for accessing real-time public transport data from the VVO (Verkehrsverbund Oberelbe) network",
  "license": "MIT",
  "type": "library",
  "homepage": "https://github.com/B0bbyD0llar/vvophp",
  "require": {
    "php": ">=8.2",
    "ext-curl": "*",
    "psr/log": "^2 || ^3"
  },
  "require-dev": {
    "ergebnis/composer-normalize": "^2.50",
    "ergebnis/php-cs-fixer-config": "^6.60.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^1.12.33",
    "roave/security-advisories": "dev-latest",
    "xrdebug/php": "^3.0.0",
    "phpunit/phpunit": "^11"
  },
  "autoload": {
    "psr-4": {
      "VVOphp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "VVOphp\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "ergebnis/composer-normalize": true
    }
  }
}
